# API Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api/v1

# Application
NEXT_PUBLIC_APP_NAME=Servy

# Site URL (used for SEO metadata, Open Graph, and schema.org — set to your production domain)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Platform theme (leave blank to use default)
NEXT_PUBLIC_PLATFORM_THEME=

# Resend — used to email lead notifications to business@servyworld.com
# Sign up at resend.com, verify your domain, then create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Servy <business@servyworld.com>
